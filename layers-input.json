{
    "catalog": "https://s3-west.nrp-nautilus.io/public-data/stac/catalog.json",
    "titiler_url": "https://titiler.nrp-nautilus.io",
    "mcp_url": "https://duckdb-mcp.nrp-nautilus.io/mcp",
    "view": {
        "center": [-121.5, 40.5],
        "zoom": 7
    },
    "welcome": {
        "message": "Hi! I can help you explore California gray wolf territories, pack movement data, and related environmental and political context. Try asking:",
        "examples": [
            "Tell me about the wolf datasets available.",
            "Zoom to the Whaleback pack territory.",
            "Which protected lands overlap with wolf territories?",
            "Which state assembly districts overlap with wolf packs?"
        ]
    },
    "collections": [
        {
            "collection_id": "census-2024-county",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-census/census-2024/county/stac-collection.json",
            "group": { "name": "Political Boundaries", "collapsed": true },
            "assets": [
                {
                    "id": "county-pmtiles",
                    "display_name": "CA Counties",
                    "visible": false,
                    "default_style": {
                        "fill-color": "rgba(0,0,0,0)",
                        "fill-opacity": 0
                    },
                    "outline_style": {
                        "line-color": "#616161",
                        "line-width": 1.5
                    },
                    "default_filter": ["==", ["get", "STATEFP"], "06"],
                    "tooltip_fields": ["NAME", "NAMELSAD", "GEOID"]
                }
            ]
        },
        {
