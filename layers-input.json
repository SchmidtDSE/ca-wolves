        {
            "collection_id": "ca-wolves",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-ca-wolves/stac-collection.json",
            "group": { "name": "Wolf Activity" },
            "assets": [
                {
                    "id": "territories",
                    "display_name": "Pack Territories (Feb 2025)",
                    "visible": true,
                    "default_style": {
                        "fill-color": [
                            "match", ["get", "pack"],
                            "Whaleback",        "#E65100",
                            "Harvey",           "#1565C0",
                            "Ice Cave",         "#2E7D32",
                            "Lassen",           "#6A1B9A",
                            "Diamond/Beyem Seyo","#AD1457",
                            "Yowlumni",         "#F9A825",
                            "#888888"
                        ],
                        "fill-opacity": 0.55
                    },
                    "outline_style": {
                        "line-color": "#333333",
                        "line-width": 1.2
                    },
                    "tooltip_fields": ["pack", "centroid_lon", "centroid_lat", "source"]
                },
                {
                    "id": "bins-latest",
                    "display_name": "Current Positions (~6km hexbins)",
                    "visible": true,
                    "default_style": {
                        "fill-color": [
                            "match", ["get", "pack"],
                            "Whaleback 1",       "#E65100",
                            "Whaleback 2",       "#FF6D00",
                            "Whaleback 4",       "#FFAB40",
                            "Whaleback Disperser 1", "#FFD180",
                            "Whaleback Disperser 2", "#FFE0B2",
                            "Harvey 1",          "#1565C0",
                            "Harvey 3",          "#42A5F5",
                            "Yowlumni Disperser","#F9A825",
                            "#888888"
                        ],
                        "fill-opacity": 0.7
